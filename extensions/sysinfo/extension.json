{
  "id": "sysinfo",
  "name": "System Info",
  "description": "Insights add-ons under System health: internet speed test (on-demand + auto-schedule) and a full Docker card \u2014 live container stats, compose-stack grouping, start/stop/restart, and one-click image updates \u2014 via a loopback sidecar.",
  "version": "0.1.0",
  "author": "asorourx",
  "assets": {
    "scripts": [
      "assets/sysinfo.js"
    ],
    "stylesheets": [
      "assets/sysinfo.css"
    ]
  },
  "capabilities": [
    "manifest-bundle",
    "loopback-sidecar"
  ],
  "lifecycle": {
    "webui_restart_required": false,
    "sidecar_start_required": true,
    "native_host_start_required": false,
    "native_host_autostart": "none"
  },
  "post_install": {
    "requires_local_app": true,
    "local_app_label": "System Info sidecar",
    "summary": "Run the bundled sidecar (sidecar/sidecar.py) on 127.0.0.1:17796, then approve the sidecar proxy in Settings \u2192 Extensions. Speed test needs `speedtest-cli`; the Docker card needs the docker CLI. By default no containers are shown until you set an allowlist (MC_DOCKER_NAME_ALLOW / MC_DOCKER_WORKDIR_PREFIX) or MC_DOCKER_SHOW_ALL=1."
  },
  "screenshots": [
    "screenshots/insights-light.png",
    "screenshots/insights-dark.png",
    "screenshots/docker-update.png"
  ],
  "permissions": {
    "webui_api": {
      "read": [
        "/api/extensions/status",
        "/api/extensions/sysinfo/sidecar/api/system/speedtest",
        "/api/extensions/sysinfo/sidecar/api/system/speedtest/auto",
        "/api/extensions/sysinfo/sidecar/api/system/docker",
        "/api/extensions/sysinfo/sidecar/api/system/docker/groups",
        "/api/extensions/sysinfo/sidecar/api/system/docker/update-bulk",
        "/api/extensions/sysinfo/sidecar/api/system/docker/op-status"
      ],
      "write": [
        "/api/extensions/sysinfo/sidecar/api/system/speedtest",
        "/api/extensions/sysinfo/sidecar/api/system/speedtest/auto",
        "/api/extensions/sysinfo/sidecar/api/system/docker/groups",
        "/api/extensions/sysinfo/sidecar/api/system/docker/updates",
        "/api/extensions/sysinfo/sidecar/api/system/docker/update-bulk",
        "/api/extensions/sysinfo/sidecar/api/system/docker/action",
        "/api/extensions/sysinfo/sidecar/api/system/docker/group-action",
        "/api/extensions/sysinfo/sidecar/api/system/docker/update"
      ]
    },
    "webui_navigation": false,
    "dom": {
      "owned": true,
      "mutates_core_views": true
    },
    "storage": {
      "owned": [
        "mc.docker.expanded",
        "mc.docker.group.*",
        "mc.docker.updates"
      ],
      "shared_webui_keys": []
    },
    "loopback_sidecar": true,
    "native_host": false,
    "filesystem": {
      "arbitrary": true,
      "serves_bundled_assets": true,
      "note": "Runs `docker compose pull/up` from each stack's host-derived compose working_dir, so it reads that stack's compose files/.env and whatever Docker credentials the daemon uses. Constrained to MC_DOCKER_WORKDIR_PREFIX when set."
    },
    "network_external": true
  },
  "sidecar": {
    "type": "loopback",
    "origin": "http://127.0.0.1:17796",
    "health_path": "/health",
    "proxy_auth": "token-v1",
    "runtime": {
      "kind": "vendored",
      "path": "sidecar"
    }
  }
}

{
  "id": "jarvis-voice",
  "name": "Jarvis Voice",
  "description": "Gemini Live voice shell for Hermes WebUI. Talk to Jarvis, let Gemini speak back, and route real actions through the current Hermes session via one safe run_hermes tool.",
  "version": "0.1.0",
  "author": "hermes-webui",
  "assets": {
    "scripts": ["assets/jarvis-voice.js"],
    "stylesheets": ["assets/jarvis-voice.css"]
  },
  "capabilities": ["manifest-bundle", "loopback-sidecar"],
  "sidecar": {
    "type": "loopback",
    "origin": "http://127.0.0.1:18787",
    "health_path": "/health",
    "proxy_auth": "token-v1",
    "runtime": { "kind": "vendored", "path": "sidecar" }
  },
  "lifecycle": {
    "webui_restart_required": false,
    "sidecar_start_required": true,
    "native_host_start_required": false,
    "native_host_autostart": "none"
  },
  "post_install": {
    "summary": "Enable WebUI authentication, approve Jarvis Voice in Settings → Extensions, then start the local token sidecar with GEMINI_API_KEY.",
    "requires_local_app": true,
    "local_app_label": "Jarvis token sidecar"
  },
  "screenshots": [],
  "permissions": {
    "webui_api": { "read": ["session"], "write": [] },
    "webui_navigation": false,
    "dom": { "owned": true, "mutates_core_views": true },
    "storage": { "owned": true, "shared_webui_keys": [] },
    "loopback_sidecar": true,
    "native_host": false,
    "filesystem": { "arbitrary": false, "serves_bundled_assets": true },
    "network_external": true,
    "device_microphone": true,
    "plays_audio": true,
    "drafts_composer_prompt": true,
    "invokes_hermes_send": true
  },
  "settings_schema": [
    { "key": "model", "type": "string", "label": "Gemini Live model", "default": "gemini-3.1-flash-live-preview" },
    { "key": "voice", "type": "enum", "label": "Voice", "options": ["Puck", "Charon", "Kore", "Fenrir", "Aoede"], "default": "Puck" },
    { "key": "hermesTimeoutSeconds", "type": "integer", "label": "Hermes tool timeout seconds", "default": 180 }
  ]
}

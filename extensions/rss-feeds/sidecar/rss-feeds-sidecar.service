# RSS Feeds sidecar — token-v1 loopback backend for the rss-feeds WebUI extension.
# Stdlib-only: needs just python3 (feeds are parsed with xml.etree, no pip deps),
# which is why it runs under `-S`. WebUI provisions the proxy token in the state
# dir; the scaffold resolves it. No token in this unit.
# Install: cp to ~/.config/systemd/user/ then `systemctl --user enable --now rss-feeds-sidecar`
[Unit]
Description=RSS Feeds sidecar (loopback backend for the rss-feeds WebUI extension, token-v1)
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/.hermes/webui/extensions/rss-feeds/sidecar
Environment=HERMES_WEBUI_STATE_DIR=%h/.hermes/webui
ExecStart=/usr/bin/python3 -S -u sidecar.py
# To use the OpenRouter/Gemini summary fallback, supply OPENROUTER_API_KEY /
# GEMINI_API_KEY via a user drop-in (this canonical unit intentionally carries no
# secrets): `systemctl --user edit rss-feeds-sidecar` and add an
# [Service] EnvironmentFile=%h/.hermes/.env — systemd loads it; the sidecar only
# ever reads keys from its process env (never a file). Local ollama needs no key.
Restart=on-failure

[Install]
WantedBy=default.target
